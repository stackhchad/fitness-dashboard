generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgresql://neondb_owner:npg_Y4cai9MrBktv@ep-empty-night-abf0bb93-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true")
  directUrl = env("postgresql://neondb_owner:npg_Y4cai9MrBktv@ep-empty-night-abf0bb93.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String?
  createdAt              DateTime                @default(now())
  workoutLogs            WorkoutLog[]
  bodyMeasurements       BodyMeasurement[]
  goals                  Goal[]
  performanceEvaluations PerformanceEvaluation[]
}

model WorkoutLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  sessionId      String
  isSessionStart Boolean  @default(false)
  workoutType    String?
  muscleGroup    String?
  exercise       String?
  sets           Int?
  reps           Int?
  weightKg       Float?
  durationMin    Int?
  notes          String?
  rpe            Int?
  intensity      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, exercise])
}

model BodyMeasurement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  weightKg    Float?
  heightCm    Float?
  bodyFatPct  Float?
  chestCm     Float?
  waistCm     Float?
  hipsCm      Float?
  armCm       Float?
  thighCm     Float?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model Goal {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        String
  description     String
  startValue      Float
  targetValue     Float
  currentValue    Float?
  startDate       DateTime
  targetDate      DateTime
  unit            String?
  higherIsBetter  Boolean   @default(true)
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model PerformanceEvaluation {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month            Int
  year             Int
  strengthScore    Int
  cardioScore      Int
  flexibilityScore Int
  nutritionScore   Int
  sleepScore       Int
  recoveryScore    Int
  overallScore     Float
  comments         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
}
